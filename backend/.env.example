# PostgreSQL connection string (from Supabase → Settings → Database → URI)
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Same URL — used by Prisma as the direct (non-pooled) connection
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Generate a strong random string: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

PORT=5000
NODE_ENV=production

# Your AssemblyAI key (get free at assemblyai.com)
ASSEMBLYAI_API_KEY="your-assemblyai-key-here"

# The Vercel frontend URL — set this after deploying the frontend
FRONTEND_URL="https://your-app.vercel.app"

USE_MOCK_TRANSCRIPTION=false
