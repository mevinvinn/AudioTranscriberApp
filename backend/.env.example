# PostgreSQL pooled connection string (from Supabase → Connect → Prisma, port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# PostgreSQL direct connection string — used by Prisma for migrations (port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"

PORT=5000
NODE_ENV=production

# Your AssemblyAI key (get free at assemblyai.com)
ASSEMBLYAI_API_KEY="your-assemblyai-key-here"

# The deployed frontend URL (Netlify) — set this after deploying the frontend
FRONTEND_URL="https://your-app.netlify.app"

USE_MOCK_TRANSCRIPTION=false

# Supabase project URL and service role key (Settings → API)
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_BUCKET=audio
